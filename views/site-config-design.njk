{% extends "document.njk" %}

{% from "badge/macro.njk" import badge with context %}
{% from "button/macro.njk" import button with context %}
{% from "notification-banner/macro.njk" import notificationBanner with context %}

{% block content %}
<link rel="stylesheet" href="/assets/@rmdes-indiekit-endpoint-site-config/editor.css">

<header class="page-header">
  <h1 class="page-header__title">{{ __("siteConfig.design.title") }}</h1>
  <p class="page-header__description">{{ __("siteConfig.design.description") }}</p>
</header>

{% include "partials/tab-strip.njk" %}

{# Hub flash (6.5): the pages create/delete routes redirect here with a flash
   (an error code or a deleted=1 confirmation) rather than the bare /pages 404.
   Error messages reuse the SAME shared errors map the editor uses; the delete
   confirmation uses the shared flash map. #}
{% if flash.error %}
<div class="sc-flash" aria-live="polite">
  {{ notificationBanner({
    type: "error",
    text: __("siteConfig.design.errors." + flash.error)
  }) }}
</div>
{% elif flash.success %}
<div class="sc-flash" aria-live="polite">
  {{ notificationBanner({
    type: "success",
    text: __("siteConfig.design.flash." + flash.success)
  }) }}
</div>
{% endif %}

<div class="sc-hub-grid">
  {% for surface in surfaces %}
  <article class="sc-hub-card{% if not surface.enabled %} sc-hub-card--disabled{% endif %}">
    <div class="sc-hub-card__thumb" aria-hidden="true">
      {% if surface.key == "homepage" %}
      <svg viewBox="0 0 64 44" class="sc-thumb">
        <rect x="4" y="4" width="56" height="8" rx="1"/>
        <rect x="4" y="16" width="36" height="24" rx="1"/>
        <rect x="44" y="16" width="16" height="24" rx="1" opacity="0.6"/>
      </svg>
      {% elif surface.key == "listing" %}
      <svg viewBox="0 0 64 44" class="sc-thumb">
        <rect x="4" y="4" width="56" height="10" rx="1"/>
        <rect x="4" y="18" width="56" height="10" rx="1" opacity="0.7"/>
        <rect x="4" y="32" width="56" height="10" rx="1" opacity="0.4"/>
      </svg>
      {% elif surface.key == "posttype" %}
      <svg viewBox="0 0 64 44" class="sc-thumb">
        <rect x="4" y="4" width="40" height="6" rx="1"/>
        <rect x="4" y="14" width="56" height="26" rx="1" opacity="0.5"/>
      </svg>
      {% else %}
      <svg viewBox="0 0 64 44" class="sc-thumb">
        <rect x="14" y="4" width="36" height="36" rx="2" opacity="0.5"/>
        <rect x="20" y="10" width="24" height="4" rx="1"/>
        <rect x="20" y="18" width="24" height="2" rx="1"/>
        <rect x="20" y="23" width="18" height="2" rx="1"/>
      </svg>
      {% endif %}
    </div>
    <h2 class="sc-hub-card__title">
      {{ __("siteConfig.design.hub.surfaces." + surface.key) }}
      {% if surface.enabled and not surface.isCollection and surface.hasDraft %}
      {{ badge({ color: "purple", text: __("siteConfig.design.hub.draftBadge") }) }}
      {% endif %}
    </h2>
    {% if surface.isCollection %}
      {# COLLECTION card (6.5-T5): a list of page:<slug> compositions + a "New
         page" create form. page title/route are OPERATOR INPUT — rendered via
         {{ }} (Nunjucks autoescape), NEVER | safe (stored-XSS defense).
         Clarifying copy (6.5): these are COMPOSED LAYOUT pages built from
         blocks here, distinct from Micropub CONTENT pages created via the
         posts flow. #}
      <p class="sc-hub-card__meta sc-hub-pages__clarify">{{ __("siteConfig.design.hub.pages.clarify") }}</p>
      {% if surface.pages.length %}
      <ul class="sc-hub-pages">
        {% for page in surface.pages %}
        <li class="sc-hub-pages__item">
          <a class="sc-hub-pages__edit" href="{{ page.editHref }}">
            <span class="sc-hub-pages__title">{{ page.title }}</span>
            {% if page.hasDraft %}
            {{ badge({ color: "purple", text: __("siteConfig.design.hub.draftBadge") }) }}
            {% endif %}
            <span class="sc-hub-pages__route">{{ page.route }}</span>
          </a>
          <form class="sc-hub-pages__delete" action="{{ page.deleteHref }}" method="post"
            onsubmit="return confirm('{{ __('siteConfig.design.hub.pages.confirmDelete') }}');">
            <button type="submit" class="button button--small button--destructive">{{ __("siteConfig.design.hub.pages.deletePage") }}</button>
          </form>
        </li>
        {% endfor %}
      </ul>
      {% else %}
      <p class="sc-hub-card__meta">{{ __("siteConfig.design.hub.pages.empty") }}</p>
      {% endif %}
      <form class="sc-hub-pages__create" action="{{ surface.createHref }}" method="post">
        <h3 class="sc-hub-pages__create-title">{{ __("siteConfig.design.hub.pages.newPage") }}</h3>
        <label class="sc-field">
          <span class="sc-field__label">{{ __("siteConfig.design.hub.pages.titleLabel") }}</span>
          <input class="input" type="text" name="title" required
            placeholder="{{ __('siteConfig.design.hub.pages.titlePlaceholder') }}">
        </label>
        <label class="sc-field">
          <span class="sc-field__label">{{ __("siteConfig.design.hub.pages.routeLabel") }}</span>
          <input class="input" type="text" name="route" required
            placeholder="{{ __('siteConfig.design.hub.pages.routePlaceholder') }}">
        </label>
        <button type="submit" class="button button--small">{{ __("siteConfig.design.hub.pages.create") }}</button>
      </form>
    {% elif surface.enabled %}
      {% if surface.updatedAt %}
      <p class="sc-hub-card__meta">{{ __("siteConfig.design.hub.lastEdited") }} {{ surface.updatedAt | date("PPp") }}</p>
      {% endif %}
      {{ button({
        href: surface.href,
        classes: "button--small",
        text: __("siteConfig.design.hub.edit")
      }) }}
    {% else %}
      <p class="sc-hub-card__meta">{{ __("siteConfig.design.hub.comingSoon") }}</p>
    {% endif %}
  </article>
  {% endfor %}
</div>
{% endblock %}
