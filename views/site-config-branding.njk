{% extends "document.njk" %}
{% import "partials/color-picker.njk" as cp %}
{% import "partials/role-override.njk" as ro %}

{% block title %}{{ __("siteConfig.branding.title") }}{% endblock %}

{% block content %}
<style>
  .sc-dashboard {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl, 2rem);
  }

  .sc-section {
    background: var(--color-offset, #f5f5f5);
    border-radius: var(--border-radius-small, 0.5rem);
    padding: var(--space-m, 1.5rem);
  }

  .sc-section h2 {
    font: var(--font-heading, bold 1.25rem/1.4 sans-serif);
    margin-block-end: var(--space-2xs, 0.375rem);
    padding-block-end: var(--space-xs, 0.5rem);
    border-block-end: 1px solid var(--color-outline-variant, #ddd);
  }

  .sc-section__desc {
    color: var(--color-on-offset, #666);
    font: var(--font-body, 0.875rem/1.5 sans-serif);
    margin: 0 0 var(--space-m, 1rem);
  }

  .hp-success {
    background: var(--color-success-container, #d4edda);
    border: 1px solid var(--color-success, #28a745);
    border-radius: var(--border-radius-small, 0.25rem);
    padding: var(--space-s, 0.75rem);
    margin-block-end: var(--space-m, 1rem);
  }

  /* Field grid */
  .hp-field-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-m, 1rem) var(--space-s, 0.75rem);
  }

  .hp-field-grid .field--full {
    grid-column: 1 / -1;
  }

  @media (max-width: 640px) {
    .hp-field-grid {
      grid-template-columns: 1fr;
    }
    .hp-field-grid .field--full {
      grid-column: 1;
    }
  }

  /* Field styling */
  .sc-dashboard .field {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .sc-dashboard .field__label {
    display: block;
    font: var(--font-caption, 0.75rem/1.4 sans-serif);
    font-weight: 600;
    color: var(--color-on-surface, inherit);
  }

  .sc-dashboard .field__input {
    width: 100%;
    padding: var(--space-2xs, 0.375rem) var(--space-xs, 0.5rem);
    border: 1px solid var(--color-outline-variant, #ccc);
    border-radius: var(--border-radius-small, 0.25rem);
    font: var(--font-body, 0.875rem/1.5 sans-serif);
    background: var(--color-background, #fff);
    color: var(--color-on-surface, inherit);
    transition: border-color 0.15s;
  }

  .sc-dashboard .field__input:focus {
    outline: none;
    border-color: var(--color-primary, #0066cc);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--color-primary, #0066cc) 20%, transparent);
  }

  .sc-dashboard .field__hint {
    color: var(--color-on-offset, #888);
    font: var(--font-caption, 0.75rem/1.4 sans-serif);
    margin: 0.125rem 0 0;
  }

  /* Radio group */
  .sc-radio-group {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-s, 0.75rem);
    margin-block-start: var(--space-xs, 0.5rem);
  }

  .sc-radio-label {
    display: flex;
    align-items: center;
    gap: var(--space-2xs, 0.375rem);
    cursor: pointer;
    font: var(--font-body, 0.875rem/1.5 sans-serif);
    padding: var(--space-2xs, 0.375rem) var(--space-s, 0.75rem);
    border: 1px solid var(--color-outline-variant, #ccc);
    border-radius: var(--border-radius-small, 0.25rem);
    background: var(--color-background, #fff);
    transition: border-color 0.15s, background 0.15s;
  }

  .sc-radio-label:has(input:checked) {
    border-color: var(--color-primary, #0066cc);
    background: color-mix(in srgb, var(--color-primary, #0066cc) 8%, var(--color-background, #fff));
  }

  /* Surface preset options with a tone-ramp preview */
  .sc-preset-option {
    flex-direction: column;
    align-items: stretch;
    gap: var(--space-2xs, 0.375rem);
    min-width: 9rem;
  }

  .sc-preset-option__head {
    display: flex;
    align-items: center;
    gap: var(--space-2xs, 0.375rem);
  }

  .sc-preset-ramp {
    display: flex;
    height: 0.85rem;
    border-radius: 0.2rem;
    overflow: hidden;
    border: 1px solid var(--color-outline-variant, #ddd);
  }

  .sc-preset-chip {
    flex: 1 1 0;
  }

  /* Generic color picker (palette inputs) */
  .sc-color-picker {
    display: flex;
    align-items: center;
    gap: var(--space-xs, 0.5rem);
  }

  .sc-color-picker__swatch {
    width: 2.5rem;
    height: 2.25rem;
    padding: 2px;
    border: 1px solid var(--color-outline-variant, #ccc);
    border-radius: var(--border-radius-small, 0.25rem);
    background: var(--color-background, #fff);
    cursor: pointer;
    flex-shrink: 0;
  }

  .sc-color-picker .field__input {
    flex: 1;
    min-width: 6rem;
  }

  /* Surface tones grid */
  .sc-tones-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(10rem, 1fr));
    gap: var(--space-s, 0.75rem);
  }

  /* Role-override controls (Tier 2 semantic roles) */
  .sc-role-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-m, 1rem);
  }

  .sc-role-field {
    padding: var(--space-s, 0.75rem);
    background: var(--color-background, #fff);
    border: 1px solid var(--color-outline-variant, #e0e0e0);
    border-radius: var(--border-radius-small, 0.375rem);
  }

  .sc-role-field__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-s, 0.75rem);
    margin-block-end: var(--space-2xs, 0.25rem);
  }

  .sc-role-reset {
    background: none;
    border: none;
    color: var(--color-primary, #0066cc);
    font: var(--font-caption, 0.75rem/1.4 sans-serif);
    text-decoration: underline;
    cursor: pointer;
    padding: 0;
  }

  .sc-role-reset:hover {
    text-decoration: none;
  }

  .sc-role-field__row {
    margin-block-start: var(--space-xs, 0.5rem);
  }

  .sc-role-field__inherit {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2xs, 0.375rem);
    font: var(--font-body, 0.875rem/1.5 sans-serif);
    cursor: pointer;
  }

  .sc-role-field__overrides[hidden] {
    display: none;
  }

  .sc-role-field__pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-s, 0.75rem);
    margin-block-start: var(--space-xs, 0.5rem);
  }

  @media (max-width: 640px) {
    .sc-role-field__pair {
      grid-template-columns: 1fr;
    }
  }

  .sc-role-field__mode {
    font: var(--font-caption, 0.75rem/1.4 sans-serif);
    color: var(--color-on-offset, #888);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  /* Accent suggestions */
  .sc-accent-suggestions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2xs, 0.5rem);
    margin-block-end: var(--space-s, 0.75rem);
  }

  .sc-accent-suggestion {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2xs, 0.375rem);
    padding: var(--space-2xs, 0.25rem) var(--space-xs, 0.5rem);
    border: 1px solid var(--color-outline-variant, #ccc);
    border-radius: var(--border-radius-small, 0.25rem);
    background: var(--color-background, #fff);
    font: var(--font-caption, 0.75rem/1.4 sans-serif);
    cursor: pointer;
    transition: border-color 0.15s, transform 0.1s;
  }

  .sc-accent-suggestion:hover {
    border-color: var(--color-primary, #0066cc);
    transform: translateY(-1px);
  }

  .sc-accent-swatch {
    display: inline-block;
    width: 1rem;
    height: 1rem;
    border-radius: 0.125rem;
    border: 1px solid var(--color-outline-variant, #ddd);
    flex-shrink: 0;
  }

  /* Advanced toggle */
  .sc-advanced-toggle {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2xs, 0.375rem);
    cursor: pointer;
    font: var(--font-body, 0.875rem/1.5 sans-serif);
    color: var(--color-primary, #0066cc);
  }

  .sc-advanced-content[hidden] {
    display: none;
  }

  /* Custom surface tones, hidden by default */
  .sc-surface-custom[hidden] {
    display: none;
  }

  /* Two-column layout for branding (form + preview) */
  .sc-branding-layout {
    display: grid;
    grid-template-columns: 1fr 480px;
    gap: var(--space-xl, 2rem);
    align-items: start;
  }

  @media (max-width: 1024px) {
    .sc-branding-layout {
      grid-template-columns: 1fr;
    }
  }

  .sc-preview-panel {
    position: sticky;
    top: var(--space-m, 1rem);
  }

  .sc-preview-panel h3 {
    font: var(--font-heading, bold 1rem/1.4 sans-serif);
    margin-block-end: var(--space-s, 0.75rem);
    color: var(--color-on-surface, inherit);
  }

  .sc-preview-iframe {
    width: 100%;
    height: 600px;
    border: 1px solid var(--color-outline-variant, #ccc);
    border-radius: var(--border-radius-small, 0.5rem);
    background: var(--color-background, #fff);
  }

  /* Contrast feedback — inline next to role color pickers */
  .sc-contrast-banner {
    background: var(--color-warning-container, #fff3cd);
    border: 1px solid var(--color-warning, #ffeeba);
    border-radius: var(--border-radius-small, 0.25rem);
    padding: var(--space-s, 0.75rem);
    margin-block-end: var(--space-m, 1rem);
    color: var(--color-on-warning-container, #856404);
  }

  .sc-contrast-banner--fail {
    background: var(--color-error-container, #f8d7da);
    border-color: var(--color-error, #f5c6cb);
    color: var(--color-on-error-container, #721c24);
  }

  .sc-contrast-banner h3 {
    margin: 0 0 var(--space-2xs, 0.375rem);
    font: var(--font-caption, 0.875rem/1.4 sans-serif);
    font-weight: 700;
  }

  .sc-contrast-banner ul {
    margin: 0;
    padding-inline-start: 1.25rem;
    font: var(--font-caption, 0.8125rem/1.5 sans-serif);
  }

  .sc-contrast-pill {
    display: inline-block;
    padding: 0.1rem 0.4rem;
    border-radius: 0.2rem;
    font-size: 0.6875rem;
    font-weight: 600;
    margin-inline-start: var(--space-2xs, 0.375rem);
    vertical-align: middle;
  }

  .sc-contrast-pill--pass { background: #d4edda; color: #155724; }
  .sc-contrast-pill--warn { background: #fff3cd; color: #856404; }
  .sc-contrast-pill--fail { background: #f8d7da; color: #721c24; }

  /* History list */
  .sc-history-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs, 0.5rem);
  }

  .sc-history-entry {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-s, 0.75rem);
    padding: var(--space-xs, 0.5rem) var(--space-s, 0.75rem);
    background: var(--color-background, #fff);
    border: 1px solid var(--color-outline-variant, #e0e0e0);
    border-radius: var(--border-radius-small, 0.25rem);
    font: var(--font-body, 0.875rem/1.5 sans-serif);
  }

  .sc-history-entry__meta {
    color: var(--color-on-offset, #666);
    font-size: 0.8125rem;
  }

  .sc-history-entry__index {
    display: inline-block;
    min-width: 1.5rem;
    text-align: center;
    background: var(--color-offset, #f5f5f5);
    border-radius: 0.25rem;
    padding: 0.1rem 0.4rem;
    font-weight: 600;
    margin-inline-end: var(--space-2xs, 0.375rem);
  }

  /* Section + global reset buttons */
  .sc-section__reset-row {
    display: flex;
    justify-content: flex-end;
    margin-block-start: var(--space-s, 0.75rem);
  }

  .sc-reset-btn {
    background: transparent;
    border: 1px solid var(--color-outline-variant, #ccc);
    color: var(--color-on-surface, #444);
    padding: var(--space-2xs, 0.375rem) var(--space-s, 0.75rem);
    border-radius: var(--border-radius-small, 0.25rem);
    font: var(--font-caption, 0.8125rem/1.5 sans-serif);
    cursor: pointer;
  }

  .sc-reset-btn:hover {
    border-color: var(--color-primary, #0066cc);
    color: var(--color-primary, #0066cc);
  }

  .sc-reset-btn--danger {
    border-color: var(--color-error, #dc3545);
    color: var(--color-error, #dc3545);
  }

  .sc-reset-btn--danger:hover {
    background: var(--color-error, #dc3545);
    color: #fff;
  }

  .sc-inline-form {
    display: inline;
  }

  /* Hide the per-section reset form's submit when there's already a save row */
</style>

<header class="page-header">
  <h1 class="page-header__title">{{ __("siteConfig.title") }}</h1>
  <p class="page-header__description">{{ __("siteConfig.branding.description") }}</p>
</header>

{% include "partials/tab-strip.njk" %}

{% if saved %}
<div class="hp-success">
  <p>{{ __("siteConfig.common.saved") }}{% if warn %} — {{ __("siteConfig.branding.savedWithWarnings") }}{% endif %}</p>
</div>
{% endif %}

{% if reverted %}
<div class="hp-success">
  <p>{{ __("siteConfig.branding.reverted") }}</p>
</div>
{% endif %}

{% if reset %}
<div class="hp-success">
  <p>{{ __("siteConfig.branding.resetDone") }}{% if resetSection %} ({{ resetSection }}){% endif %}</p>
</div>
{% endif %}

{% if contrastFailures and contrastFailures.length > 0 %}
<div class="sc-contrast-banner sc-contrast-banner--fail" role="alert">
  <h3>{{ __("siteConfig.branding.contrast.failTitle") }}</h3>
  <p style="margin: 0 0 var(--space-2xs, 0.375rem);">{{ __("siteConfig.branding.contrast.failHint") }}</p>
  <ul>
    {% for f in contrastFailures %}
      <li>{{ f.message }}</li>
    {% endfor %}
  </ul>
</div>
{% elif contrastWarnings and contrastWarnings.length > 0 %}
<div class="sc-contrast-banner">
  <h3>{{ __("siteConfig.branding.contrast.warnTitle") }}</h3>
  <p style="margin: 0 0 var(--space-2xs, 0.375rem);">{{ __("siteConfig.branding.contrast.warnHint") }}</p>
  <ul>
    {% for w in contrastWarnings %}
      <li>{{ w.message }}</li>
    {% endfor %}
  </ul>
</div>
{% endif %}

<div class="sc-branding-layout">

  <form method="post" action="/site-config/branding" class="sc-dashboard" id="branding-form">

    {# ──────────────────────────────────────────────────────────────
       Group 1: PALETTE
       Surface preset · Accent base · Mode
       ────────────────────────────────────────────────────────────── #}
    <section class="sc-section">
      <h2>{{ __("siteConfig.branding.groups.palette") }}</h2>
      <p class="sc-section__desc">{{ __("siteConfig.branding.groups.paletteDesc") }}</p>

      {# Surface preset #}
      <div class="field">
        <label class="field__label">{{ __("siteConfig.branding.surfacePreset") }}</label>
        <p class="field__hint">{{ __("siteConfig.branding.surfacePresetHint") }}</p>
        <div class="sc-radio-group">
          {% for preset in surfacePresets %}
            <label class="sc-radio-label sc-preset-option">
              <span class="sc-preset-option__head">
                <input type="radio" name="surfacePreset" value="{{ preset.slug }}"
                       {% if config.branding.surfacePreset == preset.slug %}checked{% endif %}>
                {{ preset.label }}
              </span>
              {% if preset.ramp %}
              <span class="sc-preset-ramp" aria-hidden="true">
                {% for tone in preset.ramp %}
                  <span class="sc-preset-chip" style="background-color: {{ tone }};"></span>
                {% endfor %}
              </span>
              {% endif %}
            </label>
          {% endfor %}
          <label class="sc-radio-label">
            <input type="radio" name="surfacePreset" value="custom"
                   {% if config.branding.surfacePreset == "custom" %}checked{% endif %}>
            {{ __("siteConfig.branding.surfacePresetCustom") }}
          </label>
        </div>
      </div>

      {# Custom surface tones (revealed only when preset=custom) #}
      <div class="sc-surface-custom"
           id="surface-custom-panel"
           {% if config.branding.surfacePreset != "custom" %}hidden{% endif %}>
        <h3 style="font: var(--font-caption, 0.75rem/1.4 sans-serif); font-weight: 600; margin: var(--space-m, 1rem) 0 var(--space-2xs, 0.375rem);">
          {{ __("siteConfig.branding.surfaceCustom") }}
        </h3>
        <p class="field__hint" style="margin-block-end: var(--space-s, 0.75rem);">
          {{ __("siteConfig.branding.surfaceCustomHint") }}
        </p>
        <div class="sc-tones-grid">
          {% for tone in [50, 100, 200, 300, 400, 500, 600, 700, 800, 900, 950] %}
            {% set toneVal = config.branding.surfaceCustom[tone] if config.branding.surfaceCustom else "#888888" %}
            {{ cp.colorPicker("surfaceCustom_" + tone, "surface-" + tone, toneVal) }}
          {% endfor %}
        </div>
      </div>

      {# Accent base + suggestions #}
      <div class="field" style="margin-block-start: var(--space-m, 1rem);">
        <label class="field__label" for="accentBase">{{ __("siteConfig.branding.accentBase") }}</label>
        <p class="field__hint">{{ __("siteConfig.branding.accentBaseHint") }}</p>

        <div class="sc-accent-suggestions" role="group" aria-label="{{ __('siteConfig.branding.accentSuggestionsLabel') }}">
          {% for suggestion in accentSuggestions %}
            <button type="button"
                    class="sc-accent-suggestion"
                    data-accent-suggestion="{{ suggestion.hex }}"
                    data-accent-slug="{{ suggestion.slug }}"
                    title="{{ suggestion.label }} ({{ suggestion.hex }})">
              <span class="sc-accent-swatch" style="background-color: {{ suggestion.hex }};"></span>
              <span>{{ suggestion.label }}</span>
            </button>
          {% endfor %}
        </div>

        <div class="sc-color-picker">
          <input type="color"
                 class="sc-color-picker__swatch"
                 id="accentBase-swatch"
                 value="{{ config.branding.accentBase or '#b45309' }}"
                 oninput="document.getElementById('accentBase').value = this.value">
          <input type="text"
                 class="field__input sc-color-picker__hex"
                 id="accentBase"
                 name="accentBase"
                 value="{{ config.branding.accentBase or '#b45309' }}"
                 pattern="^#([0-9a-fA-F]{3}|[0-9a-fA-F]{6}|[0-9a-fA-F]{8})$"
                 required
                 oninput="document.getElementById('accentBase-swatch').value = this.value">
        </div>
        {# Tracks the named slug (e.g. "amber") for the chosen suggestion;
           a manual color picker change resets this to empty. #}
        <input type="hidden" id="accentPreset" name="accentPreset"
               value="{{ config.branding.accentPreset or '' }}">
      </div>

      {# Mode #}
      <div class="field" style="margin-block-start: var(--space-m, 1rem);">
        <label class="field__label">{{ __("siteConfig.branding.mode") }}</label>
        <p class="field__hint">{{ __("siteConfig.branding.modeHint") }}</p>
        <div class="sc-radio-group">
          {% for opt in [
            {value: "light", label: __("siteConfig.branding.modeLight")},
            {value: "dark",  label: __("siteConfig.branding.modeDark")},
            {value: "auto",  label: __("siteConfig.branding.modeAuto")}
          ] %}
            <label class="sc-radio-label">
              <input type="radio" name="mode" value="{{ opt.value }}"
                     {% if config.branding.mode == opt.value %}checked{% endif %}>
              {{ opt.label }}
            </label>
          {% endfor %}
        </div>
      </div>

      <div class="sc-section__reset-row">
        <button type="button" class="sc-reset-btn"
                data-reset-section="palette">
          {{ __("siteConfig.branding.resetSection") }}
        </button>
      </div>
    </section>

    {# ──────────────────────────────────────────────────────────────
       Group 2: TEXT — heading, body, muted
       ────────────────────────────────────────────────────────────── #}
    <section class="sc-section">
      <h2>{{ __("siteConfig.branding.groups.text") }}</h2>
      <p class="sc-section__desc">{{ __("siteConfig.branding.groups.textDesc") }}</p>
      <div class="sc-role-grid">
        {{ ro.roleOverride("heading",
             __("siteConfig.branding.roles.heading"),
             __("siteConfig.branding.roles.headingHint"),
             config.branding.roles.heading,
             roleDefaults.heading) }}
        {{ ro.roleOverride("fg",
             __("siteConfig.branding.roles.fg"),
             __("siteConfig.branding.roles.fgHint"),
             config.branding.roles.fg,
             roleDefaults.fg) }}
        {{ ro.roleOverride("fgMuted",
             __("siteConfig.branding.roles.fgMuted"),
             __("siteConfig.branding.roles.fgMutedHint"),
             config.branding.roles.fgMuted,
             roleDefaults.fgMuted) }}
      </div>
      <div class="sc-section__reset-row">
        <button type="button" class="sc-reset-btn" data-reset-section="text">
          {{ __("siteConfig.branding.resetSection") }}
        </button>
      </div>
    </section>

    {# ──────────────────────────────────────────────────────────────
       Group 3: INTERACTION — link, action, focus
       ────────────────────────────────────────────────────────────── #}
    <section class="sc-section">
      <h2>{{ __("siteConfig.branding.groups.interaction") }}</h2>
      <p class="sc-section__desc">{{ __("siteConfig.branding.groups.interactionDesc") }}</p>
      <div class="sc-role-grid">
        {{ ro.roleOverride("link",
             __("siteConfig.branding.roles.link"),
             __("siteConfig.branding.roles.linkHint"),
             config.branding.roles.link,
             roleDefaults.link) }}
        {{ ro.roleOverride("action",
             __("siteConfig.branding.roles.action"),
             __("siteConfig.branding.roles.actionHint"),
             config.branding.roles.action,
             roleDefaults.action) }}
        {{ ro.roleOverride("focus",
             __("siteConfig.branding.roles.focus"),
             __("siteConfig.branding.roles.focusHint"),
             config.branding.roles.focus,
             roleDefaults.focus) }}
      </div>
      <div class="sc-section__reset-row">
        <button type="button" class="sc-reset-btn" data-reset-section="interaction">
          {{ __("siteConfig.branding.resetSection") }}
        </button>
      </div>
    </section>

    {# ──────────────────────────────────────────────────────────────
       Group 4: STRUCTURE — surface (panel), border
       ────────────────────────────────────────────────────────────── #}
    <section class="sc-section">
      <h2>{{ __("siteConfig.branding.groups.structure") }}</h2>
      <p class="sc-section__desc">{{ __("siteConfig.branding.groups.structureDesc") }}</p>
      <div class="sc-role-grid">
        {{ ro.roleOverride("surface",
             __("siteConfig.branding.roles.surface"),
             __("siteConfig.branding.roles.surfaceHint"),
             config.branding.roles.surface,
             roleDefaults.surface) }}
        {{ ro.roleOverride("border",
             __("siteConfig.branding.roles.border"),
             __("siteConfig.branding.roles.borderHint"),
             config.branding.roles.border,
             roleDefaults.border) }}
      </div>
      <div class="sc-section__reset-row">
        <button type="button" class="sc-reset-btn" data-reset-section="structure">
          {{ __("siteConfig.branding.resetSection") }}
        </button>
      </div>
    </section>

    {# ──────────────────────────────────────────────────────────────
       Advanced — page background, action-fg (default)
       Hidden by default per Theming v2 spec §16.1
       ────────────────────────────────────────────────────────────── #}
    <section class="sc-section">
      <h2>
        <label class="sc-advanced-toggle">
          <input type="checkbox" id="advanced-toggle">
          {{ __("siteConfig.branding.groups.advanced") }}
        </label>
      </h2>
      <p class="sc-section__desc">{{ __("siteConfig.branding.groups.advancedDesc") }}</p>

      <div class="sc-advanced-content" id="advanced-content" hidden>
        <div class="sc-role-grid">
          {{ ro.roleOverride("bg",
               __("siteConfig.branding.roles.bg"),
               __("siteConfig.branding.roles.bgHint"),
               config.branding.roles.bg,
               roleDefaults.bg) }}
          {{ ro.roleOverride("actionFg",
               __("siteConfig.branding.roles.actionFg"),
               __("siteConfig.branding.roles.actionFgHint"),
               config.branding.roles.actionFg,
               roleDefaults.actionFg) }}
        </div>
        <div class="sc-section__reset-row">
          <button type="button" class="sc-reset-btn" data-reset-section="advanced">
            {{ __("siteConfig.branding.resetSection") }}
          </button>
        </div>
      </div>
    </section>

    {# ──────────────────────────────────────────────────────────────
       Typography (unchanged from v1)
       ────────────────────────────────────────────────────────────── #}
    <section class="sc-section">
      <h2>{{ __("siteConfig.branding.typography") }}</h2>
      <div class="hp-field-grid">

        <div class="field">
          <label class="field__label" for="typography_sans">{{ __("siteConfig.branding.fontSans") }}</label>
          <select class="field__input" id="typography_sans" name="typography_sans">
            {% for f in curatedFonts.sans %}
              <option value="{{ f }}" {% if config.branding.typography.sans == f %}selected{% endif %}>{{ f }}</option>
            {% endfor %}
          </select>
        </div>

        <div class="field">
          <label class="field__label" for="typography_serif">{{ __("siteConfig.branding.fontSerif") }}</label>
          <select class="field__input" id="typography_serif" name="typography_serif">
            {% for f in curatedFonts.serif %}
              <option value="{{ f }}" {% if config.branding.typography.serif == f %}selected{% endif %}>{{ f }}</option>
            {% endfor %}
          </select>
        </div>

        <div class="field">
          <label class="field__label" for="typography_mono">{{ __("siteConfig.branding.fontMono") }}</label>
          <select class="field__input" id="typography_mono" name="typography_mono">
            {% for f in curatedFonts.mono %}
              <option value="{{ f }}" {% if config.branding.typography.mono == f %}selected{% endif %}>{{ f }}</option>
            {% endfor %}
          </select>
        </div>

        <div class="field">
          <label class="field__label" for="typography_hosting">{{ __("siteConfig.branding.fontHosting") }}</label>
          <select class="field__input" id="typography_hosting" name="typography_hosting">
            <option value="self"  {% if config.branding.typography.hosting == "self"  %}selected{% endif %}>Self-hosted</option>
            <option value="bunny" {% if config.branding.typography.hosting == "bunny" %}selected{% endif %}>Bunny Fonts</option>
          </select>
        </div>

      </div>
      <div class="sc-section__reset-row">
        <button type="button" class="sc-reset-btn" data-reset-section="typography">
          {{ __("siteConfig.branding.resetSection") }}
        </button>
      </div>
    </section>

    {# ──────────────────────────────────────────────────────────────
       Saved history — Phase 2c §11.2
       Each save snapshots the prior branding state. Up to 10 most-recent
       snapshots are retained. Click "Revert" to restore one (which itself
       snapshots the current state first, so the revert is undoable).
       ────────────────────────────────────────────────────────────── #}
    {% if historyEntries and historyEntries.length > 0 %}
    <section class="sc-section">
      <h2>{{ __("siteConfig.branding.history.title") }}</h2>
      <p class="sc-section__desc">{{ __("siteConfig.branding.history.desc") }}</p>
      <ol class="sc-history-list">
        {% for entry in historyEntries %}
          <li class="sc-history-entry">
            <div>
              <span class="sc-history-entry__index">#{{ loop.index }}</span>
              <span class="sc-history-entry__meta">
                {{ entry.savedAt }}
                {% if entry.snapshot and entry.snapshot.accentBase %}
                  · accent <code>{{ entry.snapshot.accentBase }}</code>
                {% endif %}
                {% if entry.snapshot and entry.snapshot.surfacePreset %}
                  · {{ entry.snapshot.surfacePreset }}
                {% endif %}
                {% if entry.snapshot and entry.snapshot.mode %}
                  · {{ entry.snapshot.mode }}
                {% endif %}
              </span>
            </div>
            <button type="button"
                    class="sc-reset-btn"
                    data-revert-index="{{ loop.index0 }}">
              {{ __("siteConfig.branding.history.revert") }}
            </button>
          </li>
        {% endfor %}
      </ol>
    </section>
    {% endif %}

    <div class="button-group">
      <button type="submit" class="button button--primary">{{ __("siteConfig.common.save") }}</button>
      <button type="button"
              class="sc-reset-btn sc-reset-btn--danger"
              data-reset-section="all"
              style="margin-inline-start: var(--space-m, 1rem);">
        {{ __("siteConfig.branding.resetAll") }}
      </button>
    </div>

  </form>

  {# Hidden helper forms for reset + revert. Buttons in the main form
     submit these by setting their index/section field and calling submit().
     This avoids nested <form> elements (invalid HTML) while keeping the
     primary <form> intact for the save flow. #}
  <form method="post" action="/site-config/branding/reset" id="sc-reset-form" style="display:none;">
    <input type="hidden" name="section" id="sc-reset-section" value="all">
  </form>
  <form method="post" action="/site-config/branding/revert" id="sc-revert-form" style="display:none;">
    <input type="hidden" name="index" id="sc-revert-index" value="0">
  </form>

  {# Live preview iframe — Phase 2c will wire it to send pending changes
     via querystring; for now it shows the saved state. #}
  <aside class="sc-preview-panel">
    <h3>{{ __("siteConfig.common.preview") }}</h3>
    <iframe src="/site-config/api/preview"
            class="sc-preview-iframe"
            title="{{ __('siteConfig.common.preview') }}"></iframe>
  </aside>

</div>

<script>
  (function () {
    // ── Surface preset radio reveals custom-tones panel ──────────
    var surfaceRadios = document.querySelectorAll('input[name="surfacePreset"]');
    var customPanel = document.getElementById('surface-custom-panel');
    function syncCustomPanel() {
      var checked = document.querySelector('input[name="surfacePreset"]:checked');
      if (!checked || !customPanel) return;
      customPanel.hidden = checked.value !== 'custom';
    }
    surfaceRadios.forEach(function (radio) {
      radio.addEventListener('change', syncCustomPanel);
    });
    syncCustomPanel();

    // ── Accent suggestion swatches populate accentBase + swatch ──
    var accentInput   = document.getElementById('accentBase');
    var accentSwatch  = document.getElementById('accentBase-swatch');
    var accentPreset  = document.getElementById('accentPreset');
    document.querySelectorAll('[data-accent-suggestion]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var hex = btn.getAttribute('data-accent-suggestion');
        var slug = btn.getAttribute('data-accent-slug');
        if (!hex) return;
        if (accentInput)  accentInput.value  = hex;
        if (accentSwatch) accentSwatch.value = hex;
        if (accentPreset) accentPreset.value = slug || '';
      });
    });
    // A manual color-input change clears the named-preset metadata.
    if (accentInput && accentPreset) {
      accentInput.addEventListener('change', function () { accentPreset.value = ''; });
    }
    if (accentSwatch && accentPreset) {
      accentSwatch.addEventListener('change', function () { accentPreset.value = ''; });
    }

    // ── Role-override inherit checkbox toggles the override row ──
    document.querySelectorAll('[data-role-inherit]').forEach(function (cb) {
      var role = cb.getAttribute('data-role-inherit');
      var panel = document.querySelector('[data-role-overrides="' + role + '"]');
      if (!panel) return;
      function sync() { panel.hidden = cb.checked; }
      cb.addEventListener('change', sync);
      sync();
    });

    // ── "Reset to default" buttons re-check the inherit checkbox ──
    document.querySelectorAll('[data-role-reset]').forEach(function (btn) {
      var role = btn.getAttribute('data-role-reset');
      var inheritCb = document.querySelector('[data-role-inherit="' + role + '"]');
      btn.addEventListener('click', function () {
        if (!inheritCb) return;
        inheritCb.checked = true;
        // Trigger change so the panel hides
        inheritCb.dispatchEvent(new Event('change'));
      });
    });

    // ── Advanced toggle reveals the bg / actionFg panel ──────────
    var advCheckbox = document.getElementById('advanced-toggle');
    var advContent  = document.getElementById('advanced-content');
    if (advCheckbox && advContent) {
      advCheckbox.addEventListener('change', function () {
        advContent.hidden = !advCheckbox.checked;
      });
    }

    // ── Section + global reset buttons ─────────────────────────────
    var resetForm = document.getElementById('sc-reset-form');
    var resetSection = document.getElementById('sc-reset-section');
    document.querySelectorAll('[data-reset-section]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var section = btn.getAttribute('data-reset-section');
        var label = section === 'all'
          ? 'Reset ALL branding to defaults? You can undo this from the Saved History list.'
          : 'Reset the ' + section + ' section to defaults? You can undo from history.';
        if (!window.confirm(label)) return;
        if (!resetForm || !resetSection) return;
        resetSection.value = section;
        resetForm.submit();
      });
    });

    // ── History revert buttons ─────────────────────────────────────
    var revertForm = document.getElementById('sc-revert-form');
    var revertIndex = document.getElementById('sc-revert-index');
    document.querySelectorAll('[data-revert-index]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var idx = btn.getAttribute('data-revert-index');
        if (!window.confirm('Revert branding to snapshot #' + (Number(idx) + 1) + '? The current state will be saved to history first so you can undo.')) return;
        if (!revertForm || !revertIndex) return;
        revertIndex.value = idx;
        revertForm.submit();
      });
    });

    // ── Live preview iframe — debounced refresh on any input event ─
    var previewIframe = document.querySelector('.sc-preview-iframe');
    var brandingForm = document.getElementById('branding-form');
    if (previewIframe && brandingForm) {
      var refreshTimer = null;
      function refreshPreview() {
        clearTimeout(refreshTimer);
        refreshTimer = setTimeout(function () {
          try {
            var fd = new FormData(brandingForm);
            var params = new URLSearchParams();
            fd.forEach(function (v, k) { params.append(k, v); });
            previewIframe.src = '/site-config/api/preview?' + params.toString();
          } catch (e) {
            // Best-effort — if FormData/URLSearchParams blow up, leave the iframe alone.
          }
        }, 200);
      }
      brandingForm.addEventListener('input', refreshPreview);
      brandingForm.addEventListener('change', refreshPreview);
    }
  })();
</script>
{% endblock %}
