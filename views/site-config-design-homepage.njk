{% extends "document.njk" %}

{% from "badge/macro.njk" import badge with context %}
{% from "button/macro.njk" import button with context %}
{% from "details/macro.njk" import details with context %}
{% from "modal-dialog/macro.njk" import modalDialog with context %}
{% from "notification-banner/macro.njk" import notificationBanner with context %}
{% from "toggle-switch/macro.njk" import toggleSwitch with context %}

{# Recipe quick-start forms; guarded=true adds the replace-draft confirm. #}
{% macro recipeForms(recipes, guarded) %}
<div class="sc-recipes">
  {% for recipe in recipes %}
  <form method="post" action="{{ surfaceBase }}/apply-recipe" class="sc-recipe"
    {%- if guarded %} onsubmit="return window.confirm(this.dataset.confirm)"
    data-confirm="{{ __('siteConfig.design.recipes.confirmReplace') }}"{% endif %}>
    <input type="hidden" name="recipeId" value="{{ recipe.id }}">
    <strong class="sc-recipe__label">{{ recipe.label }}</strong>
    <p class="sc-recipe__description">{{ recipe.description }}</p>
    <button class="button button--small">{{ __("siteConfig.design.recipes.apply") }}</button>
  </form>
  {% endfor %}
</div>
{% endmacro %}

{% block content %}
<link rel="stylesheet" href="/assets/@rmdes-indiekit-endpoint-site-config/editor.css">
<link rel="stylesheet" href="/assets/@rmdes-indiekit-endpoint-site-config/preview.css">
{# Sortable.min.js is UMD and must define the global before editor.js runs;
   deferred classic scripts and modules both execute in document order. #}
<script src="/assets/@rmdes-indiekit-endpoint-site-config/vendor/Sortable.min.js" defer></script>
<script type="module" src="/assets/@rmdes-indiekit-endpoint-site-config/editor.js"></script>
{# i18n's __() interpolates {{var}} at RENDER time (mustache: a missing
   variable becomes an empty string). Strings whose placeholders are replaced
   CLIENT-side by editor.js must be passed through as themselves
   (e.g. { seconds: "{{seconds}}" }) so the literal placeholder survives. #}
{% set editorI18n = {
  searchEmpty: __("siteConfig.design.addBlock.searchEmpty"),
  dismiss: __("siteConfig.design.flash.dismiss"),
  previewBuilding: __("siteConfig.design.previewPane.building", { seconds: "{{seconds}}" }),
  previewBuildingUnknown: __("siteConfig.design.previewPane.buildingUnknown"),
  previewReady: __("siteConfig.design.previewPane.ready"),
  previewSlow: __("siteConfig.design.previewPane.slow"),
  previewFrameTitle: __("siteConfig.design.previewPane.frameTitle", { surface: __(editorNounKey) }),
  buildBuilding: __("siteConfig.design.buildStatus.building", { seconds: "{{seconds}}" }),
  buildBuildingUnknown: __("siteConfig.design.buildStatus.buildingUnknown"),
  buildLive: __("siteConfig.design.buildStatus.live", { time: "{{time}}" }),
  buildFailed: __("siteConfig.design.buildStatus.failed"),
  buildRetryHint: __("siteConfig.design.buildStatus.retryHint"),
  buildStuck: __("siteConfig.design.buildStatus.stuck"),
  buildUnknown: __("siteConfig.design.buildStatus.unknown")
} %}
<script type="application/json" id="sc-editor-i18n">{{ editorI18n | dump | replace("</", "<\\/") | safe }}</script>

<header class="page-header">
  {# Per-surface editor copy (6.3 #28): editorTitleKey/editorIntroKey are i18n
     KEYS from the surface registry. Homepage resolves to the existing
     editor.title/description strings (byte-identical); listing resolves to its
     own listingTitle/listingDescription. #}
  <h1 class="page-header__title">{{ __(editorTitleKey) }}</h1>
  <p class="page-header__description">{{ __(editorIntroKey) }}</p>
</header>

{% include "partials/tab-strip.njk" %}

<div class="sc-flash" aria-live="polite">
  {% if success == "removed" %}
  <div class="sc-flash__undo-wrap" data-sc-undo-flash>
    {{ notificationBanner({
      type: "success",
      text: __("siteConfig.design.flash.removed", { label: removedLabel })
    }) }}
    {% if undo %}
    <form method="post" action="{{ surfaceBase }}/blocks/restore" class="sc-flash__undo">
      <input type="hidden" name="u" value="{{ undo.token }}">
      <button class="button button--small">{{ __("siteConfig.design.actions.undo") }}</button>
    </form>
    {% elif undoUnavailable %}
    <p class="sc-flash__note">{{ __("siteConfig.design.flash.undoUnavailable") }}</p>
    {% endif %}
  </div>
  {% elif success %}
  {{ notificationBanner({
    type: "success",
    text: __("siteConfig.design.flash." + success)
  }) }}
  {% if success == "arranged" and sidebarMoved %}
  <p class="sc-flash__note">{{ __("siteConfig.design.flash.sidebarMoved", { count: sidebarMoved }) }}</p>
  {% endif %}
  {% endif %}
  {% if error %}
  {{ notificationBanner({
    type: "error",
    text: __("siteConfig.design.errors." + error, { surface: __(editorNounKey) })
  }) }}
  {% endif %}
  {% if fieldErrors and fieldErrors.length %}
  {{ notificationBanner({
    type: "error",
    text: __("siteConfig.design.errors.config-invalid")
  }) }}
  {% endif %}
</div>

{% if noComposition %}
<div class="sc-empty-state">
  <p>{{ __("siteConfig.design.empty.explainer", { surface: __(editorNounKey) }) }}</p>
  <h2>{{ __("siteConfig.design.recipes.title") }}</h2>
  <p>{{ __("siteConfig.design.recipes.intro") }}</p>
  {{ recipeForms(recipes, false) }}
</div>

{% elif customTree %}
<div class="sc-custom-notice">
  {{ notificationBanner({
    type: "message",
    text: __("siteConfig.design.custom.notice", { surface: __(editorNounKey) })
  }) }}
  <p>{{ __("siteConfig.design.custom.hint") }}</p>
</div>

{% else %}
{# ---- the two-pane editor ---- #}
{# visibleZones is built from the SURFACE'S zone vocabulary (zoneNames, e.g.
   homepage's ["hero","main","sidebar","footer"] or listing's ["sidebar"]). Each
   zone is pushed only when the surface's zone-model declares it ("<zone>" in
   zoneNames), so a sidebar-only surface (listing) renders just its sidebar
   editor — no empty hero/main/footer. For homepage zoneNames contains all four,
   so every membership guard is true and the rendered CONTENT is unchanged from
   before this gate (the guards add only insignificant inter-block whitespace).
   The arrangement axis (sidebar visibility under stack vs sidebar-right, and the
   always-on footer in advanced mode) is gated on supportsArrangement so a
   no-arrangement surface shows its zone whenever the model declares it. #}
{% set visibleZones = [] %}
{% if "hero" in zoneNames %}
  {% set _push = visibleZones.push({ name: "hero", cards: [blocks.hero] if blocks.hero else [] }) %}
{% endif %}
{% if "main" in zoneNames %}
  {% set _push = visibleZones.push({ name: "main", cards: blocks.main }) %}
{% endif %}
{# Sidebar shows for sidebar-right, or whenever it still holds blocks under
   stack (orphans stay visible and manageable — mirror the footer pattern); a
   surface WITHOUT an arrangement axis shows it whenever the model declares it. #}
{% if "sidebar" in zoneNames %}
  {% if not supportsArrangement or zones.arrangement == "sidebar-right" or blocks.sidebar.length %}
  {% set _push = visibleZones.push({ name: "sidebar", cards: blocks.sidebar }) %}
  {% endif %}
{% endif %}
{% if "footer" in zoneNames %}
  {% if mode == "advanced" or blocks.footer.length %}
  {% set _push = visibleZones.push({ name: "footer", cards: blocks.footer }) %}
  {% endif %}
{% endif %}

<div class="sc-design">
  <div class="sc-design__editor">

    {# Mode row. The hidden "simple" is only rendered in advanced mode so the
       toggle submits exactly one value on both JS (change-submit) paths:
       checking sends mode=advanced, unchecking sends the hidden mode=simple. #}
    <form method="post" action="/site-config/design/mode" class="sc-mode-form">
      {% if mode == "advanced" %}<input type="hidden" name="mode" value="simple">{% endif %}
      {{ toggleSwitch({
        name: "mode",
        label: __("siteConfig.design.mode.advanced"),
        checked: mode == "advanced",
        value: "advanced",
        submitOnChange: true
      }) }}
      <noscript><button class="button button--small button--secondary">{{ __("siteConfig.design.mode.apply") }}</button></noscript>
    </form>

    {# Recipes (replace the current draft) #}
    {% call details({ classes: "sc-recipes-disclosure", summary: __("siteConfig.design.recipes.title") }) %}
      <p>{{ __("siteConfig.design.recipes.intro") }}</p>
      {{ recipeForms(recipes, true) }}
    {% endcall %}

    {# Arrangement picker: advanced mode AND a surface that has an arrangement
       axis (6.3-T2 capability gate). Homepage supportsArrangement is truthy, so
       this renders exactly as before; a sidebar-only surface gets no form. #}
    {% if mode == "advanced" and supportsArrangement %}
    <form method="post" action="{{ surfaceBase }}/arrangement" class="sc-arrangement">
      <fieldset class="sc-arrangement__fieldset">
        <legend>{{ __("siteConfig.design.arrangement.title") }}</legend>
        <div class="sc-arrangement__options">
          <label class="sc-arrangement__option">
            <input type="radio" name="arrangement" value="stack"{{ " checked" if zones.arrangement == "stack" }}>
            <svg viewBox="0 0 64 44" class="sc-thumb" aria-hidden="true">
              <rect x="4" y="4" width="56" height="10" rx="1"/>
              <rect x="4" y="18" width="56" height="10" rx="1" opacity="0.7"/>
              <rect x="4" y="32" width="56" height="10" rx="1" opacity="0.4"/>
            </svg>
            <span>{{ __("siteConfig.design.arrangement.stack") }}</span>
          </label>
          <label class="sc-arrangement__option">
            <input type="radio" name="arrangement" value="sidebar-right"{{ " checked" if zones.arrangement == "sidebar-right" }}>
            <svg viewBox="0 0 64 44" class="sc-thumb" aria-hidden="true">
              <rect x="4" y="4" width="36" height="36" rx="1"/>
              <rect x="44" y="4" width="16" height="36" rx="1" opacity="0.6"/>
            </svg>
            <span>{{ __("siteConfig.design.arrangement.sidebarRight") }}</span>
          </label>
        </div>
      </fieldset>
      <button class="button button--small">{{ __("siteConfig.design.arrangement.apply") }}</button>
    </form>
    {% endif %}

    {# Zone groups #}
    {% for zone in visibleZones %}
    <section class="sc-zone" aria-labelledby="zone-{{ zone.name }}-h">
      <h3 id="zone-{{ zone.name }}-h" class="sc-zone__title">{{ __("siteConfig.design.zones." + zone.name) }}</h3>
      <div class="sc-zone__list" data-sc-zone="{{ zone.name }}">
        {% for card in zone.cards %}
        {% include "partials/design-block-card.njk" %}
        {% else %}
        <p class="sc-zone__empty">{{ __("siteConfig.design.zones.empty") }}</p>
        {% endfor %}
      </div>
      {# JS path: opens the shared add dialog preset to this zone.
         Hidden until editor.js reveals it — the dialog needs JS. #}
      <button type="button" class="button button--small sc-zone__add" hidden
        data-modal-open="sc-add-dialog" data-sc-zone-for="{{ zone.name }}">
        {{ __("siteConfig.design.actions.add") }} — {{ __("siteConfig.design.zones." + zone.name) }}
      </button>
      {# No-JS canonical path: inline disclosure with the same add forms,
         zone fixed. (noscript content only renders when JS is off.) #}
      <noscript>
        <details class="sc-zone__add-fallback">
          <summary>{{ __("siteConfig.design.actions.add") }} — {{ __("siteConfig.design.zones." + zone.name) }}</summary>
          {% for group in availableBlocks %}
          {% for entry in group.blocks %}
          {% if zone.name in entry.regions and not entry.dormant %}
          <form method="post" action="{{ surfaceBase }}/blocks/add" class="sc-add-entry">
            <input type="hidden" name="type" value="{{ entry.id }}">
            <input type="hidden" name="zone" value="{{ zone.name }}">
            <span class="sc-add-entry__body">
              <strong>{{ entry.label }}</strong>
              {% if group.group != "built-in" %}<small> · {{ group.group }}</small>{% endif %}
              {% if entry.description %}<small class="sc-add-entry__description">{{ entry.description }}</small>{% endif %}
            </span>
            <button class="button button--small">{{ __("siteConfig.design.actions.add") }}</button>
          </form>
          {% endif %}
          {% endfor %}
          {% endfor %}
        </details>
      </noscript>
    </section>
    {% endfor %}

    {# Draft bar #}
    <div class="sc-draft-bar{% if isDraft %} sc-draft-bar--draft{% endif %}">
      {% if isDraft %}
      <p class="sc-draft-bar__status">
        {{ badge({ color: "purple", text: __("siteConfig.design.draftBar.draft") }) }}
        {% if draftUpdatedAt %}
        {{ __("siteConfig.design.draftBar.autosaved") }}
        <time datetime="{{ draftUpdatedAt }}">{{ draftUpdatedAt | date("PPp") }}</time>
        {% endif %}
      </p>
      <form method="post" action="{{ surfaceBase }}/publish" class="sc-mini-form">
        <button class="button button--small button--primary">{{ __("siteConfig.design.actions.publish") }}</button>
      </form>
      <form method="post" action="{{ surfaceBase }}/discard" class="sc-mini-form"
        onsubmit="return window.confirm(this.dataset.confirm)"
        data-confirm="{{ __('siteConfig.design.confirms.discard', { surface: __(editorNounKey) }) }}">
        <button class="button button--small button--secondary">{{ __("siteConfig.design.actions.discard") }}</button>
      </form>
      {% else %}
      <p class="sc-draft-bar__status">{{ __("siteConfig.design.draftBar.live", { surface: __(editorNounKey) }) }}</p>
      {# Publish-flow build-status strip (Phase 5 S2): renders ONLY on the
         publish flash (?published=<epoch> — the value is the publish time,
         never rendered) with the LAST-KNOWN status server-side (no-JS path;
         the noscript note says reload to update — no meta-refresh).
         editor.js takes over with epoch-aware 5s polling of the
         build-status API. Unrecognized states render the neutral copy. #}
      {% if success == "published" %}
      <div class="sc-build-status" data-sc-build-status aria-live="polite">
        <p class="sc-build-status__text" data-sc-build-text>
          {%- if buildStatus.state == "building" and buildStatus.stuck %}
          {{ __("siteConfig.design.buildStatus.stuck") }}
          {%- elif buildStatus.state == "building" %}
          {%- if buildStatus.lastOkDurationSeconds is number and buildStatus.lastOkDurationSeconds > 0 %}
          {{ __("siteConfig.design.buildStatus.building", { seconds: buildStatus.lastOkDurationSeconds | round }) }}
          {%- else %}
          {{ __("siteConfig.design.buildStatus.buildingUnknown") }}
          {%- endif %}
          {%- elif buildStatus.state == "ok" and buildStatus.finishedAt %}
          <time datetime="{{ buildStatus.finishedAt }}">{{ __("siteConfig.design.buildStatus.live", { time: buildStatus.finishedAt | date("PPp") }) }}</time>
          {%- elif buildStatus.state == "failed" %}
          {{ __("siteConfig.design.buildStatus.failed") }}
          {%- if buildStatus.error %} {{ buildStatus.error | truncate(140) }}{% endif %}
          {{ __("siteConfig.design.buildStatus.retryHint") }}
          {%- else %}
          {{ __("siteConfig.design.buildStatus.unknown") }}
          {%- endif %}
        </p>
        <noscript><p class="sc-build-status__note">{{ __("siteConfig.design.buildStatus.reloadNote") }}</p></noscript>
      </div>
      {% endif %}
      {% endif %}
    </div>
  </div>

  {# Right pane: Structural (Phase 4 skeleton, default) | Preview (Phase 5
     true preview — the theme renders preview-draft.json through the
     PRODUCTION renderer at /preview/<token>/). Pane choice is server state
     (?pane=preview) via plain links, so no-JS toggles by full reload. #}
  <div class="sc-design__pane">
    {# Live preview is now a per-surface capability for EVERY surface (#32):
       each surface owns an ISOLATED slot keyed by routeKey
       (previews.<routeKey> + preview-<routeKey>.json), so the Structural/Preview
       toggle + the chosen pane ALWAYS render. The preview iframe points at the
       surface's own /preview/<previewRouteKey>/<token>/ page. The structural
       editing pane (the block list) lives in sc-design__editor above. #}
    <nav class="sc-pane-toggle" aria-label="{{ __('siteConfig.design.previewPane.toggleLabel') }}">
      <a class="sc-pane-toggle__link" href="{{ surfaceBase }}"
        {%- if pane != "preview" %} aria-current="true"{% endif %}>{{ __("siteConfig.design.previewPane.structural") }}</a>
      <a class="sc-pane-toggle__link" href="{{ surfaceBase }}?pane=preview"
        {%- if pane == "preview" %} aria-current="true"{% endif %}>{{ __("siteConfig.design.previewPane.live") }}</a>
    </nav>
    {% if pane == "preview" %}
    {% include "partials/design-preview-live.njk" %}
    {% else %}
    {% include "partials/design-preview.njk" %}
    {% endif %}
  </div>
</div>

{# The shared add-block dialog (one per page; zone preset by editor.js) #}
{% call modalDialog({
  id: "sc-add-dialog",
  title: __("siteConfig.design.addBlock.title"),
  closeLabel: __("siteConfig.design.actions.close")
}) %}
  <div class="sc-add-search">
    <label for="sc-add-filter">{{ __("siteConfig.design.addBlock.search") }}</label>
    <input type="search" id="sc-add-filter" data-sc-filter autocomplete="off">
    <p class="sc-add-search__empty" data-sc-filter-empty hidden>{{ __("siteConfig.design.addBlock.searchEmpty") }}</p>
  </div>
  {% for group in availableBlocks %}
  <section class="sc-add-group" data-sc-group>
    <h4 class="sc-add-group__title">{{ __("siteConfig.design.addBlock.builtIn") if group.group == "built-in" else group.group }}</h4>
    {% for entry in group.blocks %}
    {% if entry.dormant %}
    <div class="sc-block-dormant" data-sc-label="{{ entry.label }}">
      <strong>{{ entry.label }}</strong>
      <p>{{ __("siteConfig.design.addBlock.dormant", { plugin: group.group }) }}</p>
    </div>
    {% elif entry.regions.length %}
    {# entries whose every legal zone is hidden under the current arrangement
       have empty regions and are skipped entirely #}
    <form method="post" action="{{ surfaceBase }}/blocks/add" class="sc-add-entry"
      data-sc-label="{{ entry.label }}">
      <input type="hidden" name="type" value="{{ entry.id }}">
      <span class="sc-add-entry__icon" aria-hidden="true">{{ icon(entry.icon) or icon("note") }}</span>
      <span class="sc-add-entry__body">
        <strong>{{ entry.label }}</strong>
        {% if entry.description %}<small class="sc-add-entry__description">{{ entry.description }}</small>{% endif %}
      </span>
      <label class="sc-add-entry__zone">
        <span>{{ __("siteConfig.design.addBlock.zone") }}</span>
        <select name="zone" data-sc-zone-select>
          {% for region in entry.regions %}
          <option value="{{ region }}">{{ __("siteConfig.design.zones." + region) }}</option>
          {% endfor %}
        </select>
      </label>
      <button class="button button--small">{{ __("siteConfig.design.actions.add") }}</button>
    </form>
    {% endif %}
    {% endfor %}
  </section>
  {% endfor %}
{% endcall %}
{% endif %}
{% endblock %}
